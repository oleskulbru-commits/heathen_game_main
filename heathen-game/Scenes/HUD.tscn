[node name="HealthPanel" type="PanelContainer" parent="."]
offset_left = 24.0
offset_top = 24.0
offset_right = 360.0
offset_bottom = 112.0

[node name="HealthMargin" type="MarginContainer" parent="HealthPanel"]
