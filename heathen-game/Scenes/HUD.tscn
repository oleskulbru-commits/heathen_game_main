[node name="GameOverMargin" type="MarginContainer" parent="GameOverOverlay/GameOverCenter/GameOverPanel"]
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="GameOverVBox" type="VBoxContainer" parent="GameOverOverlay/GameOverCenter/GameOverPanel/GameOverMargin"]
