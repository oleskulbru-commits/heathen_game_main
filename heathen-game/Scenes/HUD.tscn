[node name="GameOverCenter" type="CenterContainer" parent="GameOverOverlay"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="GameOverPanel" type="PanelContainer" parent="GameOverOverlay/GameOverCenter"]
