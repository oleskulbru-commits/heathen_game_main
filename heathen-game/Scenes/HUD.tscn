[node name="HealthLabel" type="Label" parent="HealthPanel/HealthMargin/HealthVBox"]
text = "Health 100 / 100"

[node name="HealthBar" type="ProgressBar" parent="HealthPanel/HealthMargin/HealthVBox"]
custom_minimum_size = Vector2(0, 22)
max_value = 100.0
value = 100.0
show_percentage = false

[node name="GameOverOverlay" type="Control" parent="."]
visible = false
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Backdrop" type="ColorRect" parent="GameOverOverlay"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
